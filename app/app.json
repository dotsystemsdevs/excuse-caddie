{
  "expo": {
    "name": "Excuse Caddie",
    "slug": "app-golfexcuse",
    "version": "1.5.2",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#508560"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dotsystems.appgolfexcuse",
      "appStoreUrl": "https://apps.apple.com/us/app/bogey-blamer-golf-excuses/id6759191239",
      "config": {
        "usesNonExemptEncryption": false
      },
      "buildNumber": "10",
      "infoPlist": {
        "UISupportedInterfaceOrientations": [
          "UIInterfaceOrientationPortrait"
        ],
        "UISupportedInterfaceOrientations~ipad": [
          "UIInterfaceOrientationPortrait",
          "UIInterfaceOrientationPortraitUpsideDown",
          "UIInterfaceOrientationLandscapeLeft",
          "UIInterfaceOrientationLandscapeRight"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#508560"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.dotsystems.appgolfexcuse",
      "versionCode": 11,
      "playStoreUrl": "https://play.google.com/store/apps/details?id=com.dotsystems.appgolfexcuse",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "blockedPermissions": [
        "android.permission.ACTIVITY_RECOGNITION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-audio",
      "expo-asset",
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "36.0.0"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "817260d8-54b3-4c01-9523-f4b328c72313"
      },
      "privacyPolicyUrl": "https://dotsystemsdevs.github.io/app-legal-docs/app-golfexcuse/privacy.html"
    }
  }
}
