# Vercel KV / Upstash Redis credentials.
# When you connect a Vercel KV / Marketplace Redis store to this project,
# Vercel auto-injects these as KV_REST_API_URL and KV_REST_API_TOKEN.
# For local dev, run `vercel env pull .env.local` after linking the project.

KV_REST_API_URL=
KV_REST_API_TOKEN=

# Or use Upstash directly (either pair works):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
